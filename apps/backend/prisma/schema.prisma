generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  student
  instructor
  admin
}

enum UserStatus {
  active
  locked
  deleted
}

enum CourseStatus {
  draft
  pending
  published
  archived
  rejected
}

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum LessonType {
  video
  document
  quiz
}

enum PositionType {
  video_timestamp
  document_page
  none
}

enum QuestionStatus {
  pending
  answered
  closed
}

enum EnrollStatus {
  active
  completed
  cancelled
}

enum OrderStatus {
  pending
  processing
  paid
  failed
  cancelled
  refunded
  expired
}

enum PaymentStatus {
  initiated
  success
  failed
  refunded
}

enum QuizOptionType {
  single
  multiple
  true_false
}

enum MaterialStatus {
  uploaded
  parsing
  parsed
  ready
  failed
}

enum ModerationStatus {
  pending // chờ/đang phân lớp
  approved // hợp lệ (it) hoặc admin duyệt lại OK
  rejected // model từ chối — còn được kiến nghị
  appealing // user đã kiến nghị — chờ admin
  locked // admin xác nhận từ chối — không kiến nghị lại được
}

enum MindmapStatus {
  pending // chưa tạo
  generating // đang sinh sơ đồ (background job)
  ready // đã có sơ đồ
  failed // sinh lỗi
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  fullName     String     @map("full_name")
  avatarUrl    String?    @map("avatar_url")
  phone        String?
  role         UserRole   @default(student)
  status       UserStatus @default(active)
  bio          String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  courses              Course[]
  enrollments          Enrollment[]
  orders               Order[]
  notes                Note[]
  quickQuestions       QuickQuestion[]
  questionReplies      QuestionReply[]
  reviews              Review[]
  reviewReports        ReviewReport[]
  communityPosts       CommunityPost[]
  postComments         PostComment[]
  postVotes            PostVote[]
  commentVotes         CommentVote[]
  notifications        Notification[]
  conversationsAsUser1 Conversation[]     @relation("ConvUser1")
  conversationsAsUser2 Conversation[]     @relation("ConvUser2")
  sentMessages         Message[]          @relation("SentMessages")
  conversationReads    ConversationRead[]
  messageReactions     MessageReaction[]
  aiConversations      AiConversation[]
  reviewQuizzes        ReviewQuiz[]
  coupons              Coupon[]

  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?    @map("parent_id")
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  courses     Course[]

  @@map("categories")
}

model Course {
  id               String       @id @default(uuid())
  instructorId     String       @map("instructor_id")
  categoryId       String?      @map("category_id")
  title            String
  slug             String       @unique
  description      String?      @db.Text
  shortDescription String?      @map("short_description") @db.Text
  price            Decimal      @default(0) @db.Decimal(12, 2)
  discountPrice    Decimal?     @map("discount_price") @db.Decimal(12, 2)
  thumbnailUrl     String?      @map("thumbnail_url")
  level            CourseLevel  @default(beginner)
  language         String       @default("vi")
  status           CourseStatus @default(draft)
  rejectionReason  String?      @map("rejection_reason")
  avgRating        Float        @default(0) @map("avg_rating")
  totalStudents    Int          @default(0) @map("total_students")
  totalLessons     Int          @default(0) @map("total_lessons")
  totalDurationSec Int          @default(0) @map("total_duration_sec")
  createdAt        DateTime     @default(now()) @map("created_at")
  publishedAt      DateTime?    @map("published_at")

  objectives     String[] @default([])
  targetAudience String[] @default([]) @map("target_audience")
  requirements   String[] @default([])

  welcomeMessage         String? @map("welcome_message") @db.Text
  congratulationsMessage String? @map("congratulations_message") @db.Text

  moderationStatus ModerationStatus @default(pending) @map("moderation_status")
  moderationLabel  String?          @map("moderation_label")
  moderationScore  Float?           @map("moderation_score")
  moderationReason String?          @map("moderation_reason")
  appealReason     String?          @map("appeal_reason")
  moderatedAt      DateTime?        @map("moderated_at")

  instructor         User                @relation(fields: [instructorId], references: [id])
  category           Category?           @relation(fields: [categoryId], references: [id])
  sections           Section[]
  enrollments        Enrollment[]
  orderItems         OrderItem[]
  reviews            Review[]
  communityPosts     CommunityPost[]
  chunks             CourseChunk[]
  aiConversations    AiConversation[]
  reviewQuizzes      ReviewQuiz[]
  referenceMaterials ReferenceMaterial[]
  mindmap            CourseMindmap?
  raptorTree         CourseRaptorTree?
  raptorNodes        RaptorNode[]
  coupons            Coupon[]

  @@index([instructorId])
  @@index([categoryId])
  @@index([status])
  @@index([moderationStatus])
  @@map("courses")
}

model Section {
  id         String   @id @default(uuid())
  courseId   String   @map("course_id")
  title      String
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("sections")
}

model Lesson {
  id          String     @id @default(uuid())
  sectionId   String     @map("section_id")
  title       String
  description String?    @db.Text
  type        LessonType
  orderIndex  Int        @map("order_index")
  durationSec Int        @default(0) @map("duration_sec")
  isPreview   Boolean    @default(false) @map("is_preview")
  createdAt   DateTime   @default(now()) @map("created_at")

  // Kiểm duyệt AI cho nội dung bài học (description + contentHtml + file tài liệu)
  // — cùng pattern với Course. Chỉ nội dung approved mới được index vào vector store.
  moderationStatus ModerationStatus @default(pending) @map("moderation_status")
  moderationLabel  String?          @map("moderation_label")
  moderationScore  Float?           @map("moderation_score")
  moderationReason String?          @map("moderation_reason")
  appealReason     String?          @map("appeal_reason")
  moderatedAt      DateTime?        @map("moderated_at")

  section        Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  videoAsset     VideoAsset?
  documentAsset  DocumentAsset?
  quizLesson     QuizLesson?
  reviewQuiz     ReviewQuiz?
  podcastAsset   PodcastAsset?
  lessonProgress LessonProgress[]
  notes          Note[]
  quickQuestions QuickQuestion[]

  @@index([sectionId])
  @@index([moderationStatus])
  @@map("lessons")
}

model VideoAsset {
  id               String  @id @default(uuid())
  lessonId         String  @unique @map("lesson_id")
  videoUrl         String? @map("video_url")
  hlsUrl           String? @map("hls_url")
  thumbnailUrl     String? @map("thumbnail_url")
  fileName         String? @map("file_name")
  transcript       String? @db.Text
  durationSec      Int     @default(0) @map("duration_sec")
  processingStatus String  @default("pending") @map("processing_status")
  completionMode   String  @default("percent_90") @map("completion_mode")

  // Tự động sinh phụ đề (cues) + phân tích nội dung theo khung thời gian (segments)
  // bằng Gemini, chạy nền sau khi upload. Không chặn playback.
  transcriptStatus String  @default("none") @map("transcript_status") // none|pending|processing|ready|failed
  transcriptLang   String? @map("transcript_lang")
  transcriptError  String? @map("transcript_error")
  cuesJson         Json    @default("[]") @map("cues_json") // [{ startSec, endSec, text }]
  segmentsJson     Json    @default("[]") @map("segments_json") // [{ startSec, endSec, title, summary }]
  // "percent_90" = xem đủ 90% thời lượng là hoàn thành
  // "ended_autonext" = phải xem hết video, tự động qua bài kế

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("video_assets")
}

model DocumentAsset {
  id             String  @id @default(uuid())
  lessonId       String  @unique @map("lesson_id")
  fileUrl        String? @map("file_url")
  fileName       String? @map("file_name")
  fileType       String  @default("pdf") @map("file_type")
  pageCount      Int     @default(0) @map("page_count")
  fileSize       BigInt  @default(0) @map("file_size")
  contentHtml    String? @map("content_html") @db.Text
  minReadTimeSec Int     @default(0) @map("min_read_time_sec")

  // Trạng thái chuyển đổi file PDF/DOCX → markdown (LlamaParse) + index cho AI
  markdownUrl     String?        @map("markdown_url")
  llamaParseJobId String?        @map("llama_parse_job_id")
  parseStatus     MaterialStatus @default(uploaded) @map("parse_status")
  errorMsg        String?        @map("error_msg")
  chunkCount      Int            @default(0) @map("chunk_count")
  tocJson         Json           @default("[]") @map("toc_json") // cây TOC [{title, level, children[]}]
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("document_assets")
}

// Podcast (audio) tự sinh bằng AI từ nội dung bài đọc (document):
// LLM viết kịch bản lời dẫn → Google Cloud TTS đọc thành MP3 → lưu R2.
// Chạy nền (BullMQ); không chặn việc đọc bài. Hiển thị khi status='ready'.
model PodcastAsset {
  id          String   @id @default(uuid())
  lessonId    String   @unique @map("lesson_id")
  status      String   @default("pending") // pending|processing|ready|failed
  audioUrl    String?  @map("audio_url")
  durationSec Int      @default(0) @map("duration_sec")
  voice       String?
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("podcast_assets")
}

model QuizLesson {
  id           String @id @default(uuid())
  lessonId     String @unique @map("lesson_id")
  passingScore Int    @default(70) @map("passing_score")
  timeLimit    Int?   @map("time_limit")
  maxAttempts  Int    @default(0) @map("max_attempts")

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quiz_lessons")
}

model QuizQuestion {
  id           String         @id @default(uuid())
  quizLessonId String         @map("quiz_lesson_id")
  content      String         @db.Text
  questionType QuizOptionType @default(single) @map("question_type")
  orderIndex   Int            @map("order_index")
  points       Int            @default(1)
  explanation  String?        @db.Text

  quizLesson QuizLesson          @relation(fields: [quizLessonId], references: [id], onDelete: Cascade)
  options    QuizOption[]
  answers    QuizAttemptAnswer[]

  @@map("quiz_questions")
}

model QuizOption {
  id         String  @id @default(uuid())
  questionId String  @map("question_id")
  content    String  @db.Text
  isCorrect  Boolean @default(false) @map("is_correct")
  orderIndex Int     @map("order_index")

  question QuizQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  QuizAttemptAnswer[]

  @@map("quiz_options")
}

model QuizAttempt {
  id           String    @id @default(uuid())
  quizLessonId String    @map("quiz_lesson_id")
  studentId    String    @map("student_id")
  score        Float     @default(0)
  isPassed     Boolean   @default(false) @map("is_passed")
  startedAt    DateTime  @default(now()) @map("started_at")
  submittedAt  DateTime? @map("submitted_at")

  quizLesson QuizLesson          @relation(fields: [quizLessonId], references: [id])
  answers    QuizAttemptAnswer[]

  @@index([quizLessonId, studentId])
  @@map("quiz_attempts")
}

model QuizAttemptAnswer {
  id         String @id @default(uuid())
  attemptId  String @map("attempt_id")
  questionId String @map("question_id")
  optionId   String @map("option_id")

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id])
  option   QuizOption   @relation(fields: [optionId], references: [id])

  @@map("quiz_attempt_answers")
}

// ─── Quiz ôn tập (AI) ─────────────────────────────────────────────────────────
// Bộ câu hỏi luyện tập sinh tự động bằng AI. Tách riêng khỏi QuizLesson "chính
// khoá": KHÔNG tính vào tiến độ, chấm điểm stateless (không lưu lịch sử làm bài).
// Hai dạng dùng chung 1 bảng:
//   • Quiz theo bài (dùng chung): lessonId set, userId/courseId/title = null.
//   • Quiz qua chat AI (per-user): lessonId null, userId/courseId/title set —
//     chỉ người tạo dùng được, phạm vi khoá học, nhiều quiz / người.
model ReviewQuiz {
  id        String   @id @default(uuid())
  lessonId  String?  @unique @map("lesson_id") // set = quiz theo bài (dùng chung); null = quiz qua chat
  userId    String?  @map("user_id") // set = chủ sở hữu quiz qua chat (per-user); null = quiz dùng chung
  courseId  String?  @map("course_id") // set cho quiz qua chat (phạm vi khoá)
  title     String? // tiêu đề quiz qua chat
  model     String? // model AI đã dùng để sinh (hiển thị/debug)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  lesson    Lesson?              @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course?              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions ReviewQuizQuestion[]

  @@index([userId, courseId])
  @@map("review_quizzes")
}

model ReviewQuizQuestion {
  id           String         @id @default(uuid())
  reviewQuizId String         @map("review_quiz_id")
  content      String         @db.Text
  questionType QuizOptionType @default(single) @map("question_type")
  orderIndex   Int            @map("order_index")
  explanation  String?        @db.Text

  reviewQuiz ReviewQuiz         @relation(fields: [reviewQuizId], references: [id], onDelete: Cascade)
  options    ReviewQuizOption[]

  @@index([reviewQuizId])
  @@map("review_quiz_questions")
}

model ReviewQuizOption {
  id         String  @id @default(uuid())
  questionId String  @map("question_id")
  content    String  @db.Text
  isCorrect  Boolean @default(false) @map("is_correct")
  orderIndex Int     @map("order_index")

  question ReviewQuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("review_quiz_options")
}

// ─── Tài liệu tham khảo (cấp khóa học) ─────────────────────────────────────────
// Giảng viên thêm tài liệu bổ sung cho học viên: video upload, link YouTube, hoặc
// file PDF/DOCX. Tách khỏi nội dung bài học; không vector hóa, không kiểm duyệt.
enum ReferenceMaterialType {
  video
  youtube
  file
}

model ReferenceMaterial {
  id          String                @id @default(uuid())
  courseId    String                @map("course_id")
  title       String
  description String?               @db.Text
  type        ReferenceMaterialType
  fileUrl     String?               @map("file_url") // type video|file (R2)
  fileName    String?               @map("file_name")
  fileType    String?               @map("file_type") // pdf|docx|mp4|webm
  fileSize    BigInt?               @map("file_size")
  externalUrl String?               @map("external_url") // type youtube
  orderIndex  Int                   @default(0) @map("order_index")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @default(now()) @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("reference_materials")
}

model Enrollment {
  id              String       @id @default(uuid())
  studentId       String       @map("student_id")
  courseId        String       @map("course_id")
  enrolledAt      DateTime     @default(now()) @map("enrolled_at")
  progressPercent Float        @default(0) @map("progress_percent")
  lastLessonId    String?      @map("last_lesson_id")
  status          EnrollStatus @default(active)

  student        User             @relation(fields: [studentId], references: [id])
  course         Course           @relation(fields: [courseId], references: [id])
  lessonProgress LessonProgress[]

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@map("enrollments")
}

model LessonProgress {
  id              String    @id @default(uuid())
  enrollmentId    String    @map("enrollment_id")
  lessonId        String    @map("lesson_id")
  completed       Boolean   @default(false)
  watchTimeSec    Int       @default(0) @map("watch_time_sec")
  lastPositionSec Int       @default(0) @map("last_position_sec")
  completedAt     DateTime? @map("completed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id])

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId, completed])
  @@map("lesson_progress")
}

model Note {
  id            String       @id @default(uuid())
  studentId     String       @map("student_id")
  lessonId      String       @map("lesson_id")
  content       String       @db.Text
  positionType  PositionType @default(none) @map("position_type")
  positionValue Int          @default(0) @map("position_value")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  student User   @relation(fields: [studentId], references: [id])
  lesson  Lesson @relation(fields: [lessonId], references: [id])

  @@index([studentId, lessonId])
  @@map("notes")
}

model QuickQuestion {
  id            String         @id @default(uuid())
  studentId     String         @map("student_id")
  lessonId      String         @map("lesson_id")
  content       String         @db.Text
  positionType  PositionType   @default(none) @map("position_type")
  positionValue Int            @default(0) @map("position_value")
  status        QuestionStatus @default(pending)
  isPublic      Boolean        @default(true) @map("is_public")
  createdAt     DateTime       @default(now()) @map("created_at")
  answeredAt    DateTime?      @map("answered_at")

  student User            @relation(fields: [studentId], references: [id])
  lesson  Lesson          @relation(fields: [lessonId], references: [id])
  replies QuestionReply[]

  @@index([lessonId, status])
  @@map("quick_questions")
}

model QuestionReply {
  id         String   @id @default(uuid())
  questionId String   @map("question_id")
  authorId   String   @map("author_id")
  content    String   @db.Text
  isAccepted Boolean  @default(false) @map("is_accepted")
  createdAt  DateTime @default(now()) @map("created_at")

  question QuickQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id])

  @@map("question_replies")
}

model Order {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  totalAmount    Decimal     @map("total_amount") @db.Decimal(12, 2)
  currency       String      @default("VND")
  status         OrderStatus @default(pending)
  paymentMethod  String?     @map("payment_method")
  discountCode   String?     @map("discount_code")
  discountAmount Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  idempotencyKey String      @unique @map("idempotency_key")
  createdAt      DateTime    @default(now()) @map("created_at")
  paidAt         DateTime?   @map("paid_at")

  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
  payment Payment?

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id       String  @id @default(uuid())
  orderId  String  @map("order_id")
  courseId String  @map("course_id")
  price    Decimal @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id])

  @@map("order_items")
}

model Payment {
  id           String        @id @default(uuid())
  orderId      String        @unique @map("order_id")
  gateway      String        @default("sepay")
  transferCode String?       @unique @map("transfer_code")
  gatewayTxnId String?       @map("gateway_txn_id")
  amount       Decimal       @db.Decimal(12, 2)
  currency     String        @default("VND")
  status       PaymentStatus @default(initiated)
  rawResponse  Json?         @map("raw_response")
  createdAt    DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  courseId  String   @map("course_id")
  rating    Int
  content   String?  @db.Text
  isHidden  Boolean  @default(false) @map("is_hidden")
  createdAt DateTime @default(now()) @map("created_at")

  student User           @relation(fields: [studentId], references: [id])
  course  Course         @relation(fields: [courseId], references: [id])
  reports ReviewReport[]

  @@unique([studentId, courseId])
  @@map("reviews")
}

enum ReviewReportReason {
  inappropriate_harmful // Nội dung không phù hợp - Có hại, bạo lực, thù hận, tội phạm
  inappropriate_other // Nội dung không phù hợp - Khác
  misconduct // Hành vi không phù hợp
  policy_violation // Vi phạm chính sách
  spam // Nội dung rác
  inappropriate_ad // Quảng cáo không phù hợp
  other // Ý khác
}

enum ReportStatus {
  pending
  resolved
  dismissed
}

model ReviewReport {
  id         String             @id @default(uuid())
  reviewId   String             @map("review_id")
  reporterId String             @map("reporter_id")
  reason     ReviewReportReason
  detail     String?            @db.Text
  status     ReportStatus       @default(pending)
  createdAt  DateTime           @default(now()) @map("created_at")
  resolvedAt DateTime?          @map("resolved_at")

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter User   @relation(fields: [reporterId], references: [id])

  @@index([status])
  @@index([reviewId])
  @@map("review_reports")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  linkUrl   String?  @map("link_url")
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Community ────────────────────────────────────────────────────────────────

enum CommunityPostType {
  question
  discussion
  announcement
}

enum CommunityPostStatus {
  active
  hidden
  deleted
}

model CommunityPost {
  id        String              @id @default(uuid())
  courseId  String              @map("course_id")
  authorId  String              @map("author_id")
  type      CommunityPostType   @default(question)
  status    CommunityPostStatus @default(active)
  title     String
  body      String              @db.Text
  media     Json?
  isPinned  Boolean             @default(false) @map("is_pinned")
  upvotes   Int                 @default(0)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  course   Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id])
  comments PostComment[]
  votes    PostVote[]

  @@index([courseId])
  @@index([authorId])
  @@map("community_posts")
}

model PostComment {
  id         String              @id @default(uuid())
  postId     String              @map("post_id")
  authorId   String              @map("author_id")
  parentId   String?             @map("parent_id")
  body       String              @db.Text
  status     CommunityPostStatus @default(active)
  isSolution Boolean             @default(false) @map("is_solution")
  upvotes    Int                 @default(0)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  post    CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])
  parent  PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies PostComment[] @relation("CommentReplies")
  votes   CommentVote[]

  @@index([postId])
  @@map("post_comments")
}

model PostVote {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_votes")
}

model CommentVote {
  id        String      @id @default(uuid())
  commentId String      @map("comment_id")
  userId    String      @map("user_id")
  createdAt DateTime    @default(now()) @map("created_at")

  comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@map("comment_votes")
}

// ─── Chat 1-1 ─────────────────────────────────────────────────────────────────

enum MessageType {
  text
  image
  file
  audio
  video
}

model Conversation {
  id        String   @id @default(uuid())
  user1Id   String   @map("user1_id") // luôn = min(id) theo thứ tự chuỗi
  user2Id   String   @map("user2_id") // luôn = max(id)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user1    User               @relation("ConvUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User               @relation("ConvUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]
  reads    ConversationRead[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  senderId       String      @map("sender_id")
  content        String?     @db.Text
  messageType    MessageType @default(text) @map("message_type")
  createdAt      DateTime    @default(now()) @map("created_at")
  editedAt       DateTime?   @map("edited_at")
  deletedAt      DateTime?   @map("deleted_at")

  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation("SentMessages", fields: [senderId], references: [id])
  attachments  Attachment[]
  reactions    MessageReaction[]
  readMarkers  ConversationRead[] @relation("LastReadMessage")

  @@index([conversationId])
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}

model Attachment {
  id        String @id @default(uuid())
  messageId String @map("message_id")
  fileUrl   String @map("file_url")
  fileName  String @map("file_name")
  fileSize  BigInt @default(0) @map("file_size")
  mimeType  String @map("mime_type")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

model ConversationRead {
  conversationId    String  @map("conversation_id")
  userId            String  @map("user_id")
  lastReadMessageId String? @map("last_read_message_id")

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage Message?     @relation("LastReadMessage", fields: [lastReadMessageId], references: [id])

  @@id([conversationId, userId])
  @@map("conversation_reads")
}

model MessageReaction {
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
  @@map("message_reactions")
}

// ─── RAG / AI Knowledge Base ──────────────────────────────────────────────────

model CourseMindmap {
  id         String        @id @default(uuid())
  courseId   String        @unique @map("course_id")
  title      String
  structure  Json // cây JSON chuẩn {title, summary?, keywords?, children:[]}
  markmap    String        @db.Text // markdown markmap đã derive (cache render)
  status     MindmapStatus @default(pending)
  errorMsg   String?       @map("error_msg")
  tokenUsage Int           @default(0) @map("token_usage")
  sourceHash String?       @map("source_hash")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_mindmaps")
}

model CourseChunk {
  id           String                      @id @default(uuid())
  courseId     String                      @map("course_id")
  sectionId    String?                     @map("section_id")
  lessonId     String?                     @map("lesson_id")
  sourceType   String                      @map("source_type") // 'lesson_content' | 'lesson_file'
  sectionTitle String?                     @map("section_title") // đường dẫn TOC đầy đủ "Phần > Bài > Đề mục"
  pageNumber   Int?                        @map("page_number")
  chunkIndex   Int                         @map("chunk_index")
  content      String                      @db.Text
  tokenCount   Int                         @default(0) @map("token_count")
  metadata     Json                        @default("{}")
  embedding    Unsupported("vector(768)")?
  contentTsv   Unsupported("tsvector")?    @default(dbgenerated("to_tsvector('simple'::regconfig, COALESCE(content, ''::text))")) @map("content_tsv")
  createdAt    DateTime                    @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([sectionId])
  @@index([lessonId])
  @@map("course_chunks")
}

// ─── RAPTOR (cây tóm tắt phân cấp) ───────────────────────────────────────────

// Meta build cây RAPTOR theo từng khóa — cache theo source_hash giống CourseMindmap.
model CourseRaptorTree {
  courseId   String        @id @map("course_id")
  status     MindmapStatus @default(pending)
  errorMsg   String?       @map("error_msg")
  tokenUsage Int           @default(0) @map("token_usage")
  sourceHash String?       @map("source_hash")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_raptor_trees")
}

// Node tóm tắt các tầng của cây RAPTOR (lá = course_chunks, không nhân bản).
// level: 1 = tóm tắt bài, 2 = tóm tắt phần, 3 = gốc khóa.
model RaptorNode {
  id            String                      @id @default(uuid())
  courseId      String                      @map("course_id")
  sectionId     String?                     @map("section_id")
  lessonId      String?                     @map("lesson_id")
  level         Int
  title         String?
  content       String                      @db.Text
  childChunkIds String[]                    @default([]) @map("child_chunk_ids")
  childNodeIds  String[]                    @default([]) @map("child_node_ids")
  tokenCount    Int                         @default(0) @map("token_count")
  metadata      Json                        @default("{}")
  embedding     Unsupported("vector(768)")?
  contentTsv    Unsupported("tsvector")?    @default(dbgenerated("to_tsvector('simple'::regconfig, COALESCE(content, ''::text))")) @map("content_tsv")
  createdAt     DateTime                    @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([lessonId])
  @@index([level])
  @@map("raptor_nodes")
}

model AiConversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId, courseId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String   @db.Text
  citations      Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

// ─── Coupons ──────────────────────────────────────────────────────────────────

model Coupon {
  id           String    @id @default(uuid())
  code         String    @unique
  instructorId String    @map("instructor_id")
  courseId     String?   @map("course_id")
  discountPct  Int       @map("discount_pct") // 1-100
  maxUses      Int       @default(0) @map("max_uses") // 0 = unlimited
  usedCount    Int       @default(0) @map("used_count")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  instructor User    @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  course     Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([instructorId])
  @@index([code])
  @@map("coupons")
}

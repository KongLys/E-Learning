# Database (Supabase — get from Project Settings > Database > Connection string)
# Dùng transaction pooler (port 6543) + pgbouncer cho app runtime để tránh cạn pool.
# KHÔNG dùng port 5432 (session mode, giới hạn 15 client).
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"

# Redis
REDIS_URL="redis://localhost:6379"

# Cloudflare R2 (S3-compatible) — https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
R2_REGION="auto"
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET="elearning"
# Public base URL for the bucket (R2 public dev URL or custom domain) — used for avatars/thumbnails/preview assets
R2_PUBLIC_URL="https://pub-<hash>.r2.dev"

# App
PORT=3001
NODE_ENV=development

# JWT — change in production!
JWT_SECRET=change-me-in-production-use-32-plus-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# SePay (QR chuyển khoản ngân hàng — https://my.sepay.vn)
# Số tài khoản & mã ngân hàng của tài khoản nhận tiền (xem Công ty > Tài khoản ngân hàng)
SEPAY_ACCOUNT_NUMBER=
SEPAY_BANK_CODE=
SEPAY_ACCOUNT_NAME=
# API Key cấu hình trong Webhooks > Cấu hình chung (header Authorization: Apikey <key>)
SEPAY_API_KEY=
# URL sinh ảnh QR VietQR (mặc định dùng dịch vụ miễn phí của SePay)
SEPAY_QR_URL=https://qr.sepay.vn/img

# AI / RAG — Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
# Must match the vector(768) column in course_chunks
GEMINI_EMBED_DIMENSIONS=768
# Embeddings provider: 'gemini' (cloud, free-tier quota ~100 req/min) or 'ollama' (local, no quota)
EMBED_PROVIDER=gemini
# Chat/generation provider (hỏi đáp RAG + tóm tắt mind map): 'gemini' (cloud) hoặc 'ollama' (local, no quota)
CHAT_PROVIDER=gemini
OLLAMA_BASE_URL=http://localhost:11434
# nomic-embed-text → 768 dims, matches the vector(768) column. Run: ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text
# Model sinh văn bản khi CHAT_PROVIDER=ollama. Run: ollama pull qwen2.5:7b
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Phụ đề video (transcription) — AssemblyAI (https://www.assemblyai.com/app/account).
# Nhận dạng giọng nói có timestamp + tự nhận diện ngôn ngữ (hỗ trợ tiếng Việt).
# AssemblyAI tự tải video về từ presigned URL của R2 — không cần upload thủ công.
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_BASE_URL=https://api.assemblyai.com
# Model nhận dạng (mảng, ưu tiên đầu → fallback, ngăn cách bằng dấu phẩy).
# universal-2: $0.15/hr — rẻ nhất, hỗ trợ 99 ngôn ngữ (gồm tiếng Việt). Mặc định.
# universal-3-pro: $0.21/hr nhưng chỉ 6 ngôn ngữ (có thể KHÔNG có tiếng Việt).
ASSEMBLYAI_SPEECH_MODELS=universal-2
ASSEMBLYAI_POLL_INTERVAL_MS=5000
ASSEMBLYAI_POLL_TIMEOUT_MS=600000
# Phân chương video được sinh bằng LLM từ phụ đề (auto_chapters của AssemblyAI thiên về
# tiếng Anh nên không dùng). Mặc định Ollama cục bộ (miễn phí, không tốn quota).
# provider: 'ollama' (mặc định) hoặc 'gemini'. Để trống model = dùng model mặc định của provider.
VIDEO_CHAPTER_PROVIDER=ollama
VIDEO_CHAPTER_MODEL=

# Quiz ôn tập (AI) — sinh câu hỏi trắc nghiệm từ nội dung bài học khi người dùng bấm nút.
# provider: 'ollama' (local, mặc định, không tốn quota) hoặc 'gemini' (cloud).
REVIEW_QUIZ_PROVIDER=ollama
# Model dùng để sinh quiz. Để trống = dùng model mặc định của provider
# (OLLAMA_CHAT_MODEL nếu ollama, GEMINI_CHAT_MODEL nếu gemini).
REVIEW_QUIZ_MODEL=

# Giọng đọc (TTS) + lời dẫn video — Google Cloud Text-to-Speech.
# Tự sinh giọng đọc cho bài đọc khi khóa được duyệt xuất bản (đọc trung thực nội dung,
# hiển thị dưới tiêu đề, tự phát). Cần bật Text-to-Speech API trong Google Cloud + API key.
GOOGLE_TTS_API_KEY=
# Giọng đọc tiếng Việt, vd vi-VN-Wavenet-A/B/C/D hoặc vi-VN-Standard-A...
GOOGLE_TTS_VOICE=vi-VN-Wavenet-A
GOOGLE_TTS_LANGUAGE=vi-VN

# Video ngắn do AI tạo (~2–3 phút) cho bài đọc — LLM Ollama tóm tắt → TTS đọc từng
# section → Remotion render MP4 có timeline section. Trigger khi khóa được duyệt xuất bản.
# Bật/tắt (render Remotion cần headless Chromium, tốn CPU/thời gian; mặc định tắt).
AI_VIDEO_ENABLED=false
# Thời lượng video mục tiêu (giây) ~120–180.
AI_VIDEO_TARGET_SEC=150
# Model Ollama dùng sinh kịch bản video. Để trống = dùng OLLAMA_CHAT_MODEL.
AI_VIDEO_MODEL=

# Cohere Rerank (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=your-cohere-key
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# LlamaParse (https://cloud.llamaindex.ai — free 1000 pages/day)
LLAMA_CLOUD_API_KEY=llx-xxxxxxxxxxxxxxxxxxxxxxxx
LLAMA_PARSE_BASE_URL=https://api.cloud.llamaindex.ai
LLAMA_PARSE_LANGUAGE=vi
LLAMA_PARSE_RESULT_TYPE=markdown
LLAMA_PARSE_POLL_INTERVAL_MS=5000
LLAMA_PARSE_POLL_TIMEOUT_MS=300000

GUARDRAIL_LLM_ENABLED=
GUARDRAIL_LLM_PROVIDER=
GUARDRAIL_LLM_MODEL=

# RAG pipeline tuning
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_RETRIEVE_TOP=50
RAG_RERANK_TOP=5

# Content moderation (Python FastAPI classifier service — apps/moderation)
MODERATION_ENABLED=true
MODERATION_SERVICE_URL=http://localhost:8000
MODERATION_API_KEY=change-me
MODERATION_TIMEOUT_MS=15000
# true = nếu service kiểm duyệt lỗi/timeout thì để nội dung 'pending' chờ admin (không chặn người dùng)
MODERATION_FAIL_OPEN=true
# true = in log chi tiết từng bước kiểm duyệt (trạng thái, nhãn, điểm số, quá trình) ra backend để dễ theo dõi
MODERATION_DEBUG=false

# Database (Supabase — get from Project Settings > Database > Connection string)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO / S3
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="elearning"

# App
PORT=3001
NODE_ENV=development

# JWT — change in production!
JWT_SECRET=change-me-in-production-use-32-plus-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# VNPay (sandbox)
VNPAY_TMN_CODE=TESTCODE
VNPAY_HASH_SECRET=testhashsecret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction

# AI / RAG — Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# Cohere Rerank (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=your-cohere-key
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# LlamaParse (https://cloud.llamaindex.ai — free 1000 pages/day)
LLAMA_CLOUD_API_KEY=llx-xxxxxxxxxxxxxxxxxxxxxxxx
LLAMA_PARSE_BASE_URL=https://api.cloud.llamaindex.ai
LLAMA_PARSE_LANGUAGE=vi
LLAMA_PARSE_RESULT_TYPE=markdown
LLAMA_PARSE_POLL_INTERVAL_MS=5000
LLAMA_PARSE_POLL_TIMEOUT_MS=300000

# RAG pipeline tuning
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_RETRIEVE_TOP=50
RAG_RERANK_TOP=5

# Content moderation (Python FastAPI classifier service — apps/moderation)
MODERATION_ENABLED=true
MODERATION_SERVICE_URL=http://localhost:8000
MODERATION_API_KEY=change-me
MODERATION_TIMEOUT_MS=15000
# true = nếu service kiểm duyệt lỗi/timeout thì để nội dung 'pending' chờ admin (không chặn người dùng)
MODERATION_FAIL_OPEN=true
# true = in log chi tiết từng bước kiểm duyệt (trạng thái, nhãn, điểm số, quá trình) ra backend để dễ theo dõi
MODERATION_DEBUG=false

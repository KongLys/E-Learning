# Path to the trained HuggingFace model dir (config.json + weights + tokenizer)
MODEL_PATH=/app/models
# Max tokens per segment fed to the model (PhoBERT-base = 256)
MODEL_MAX_LENGTH=256
# Shared secret; backend must send the same value in header X-Api-Key
MODERATION_API_KEY=change-me
# Set true only on a GPU host
MODEL_USE_CUDA=false
# Log every classify request + result to the service console
LOG_REQUESTS=true
# Optional: map raw model labels -> canonical (it|spam_toxic|others)
# LABEL_MAP={"LABEL_0":"spam_toxic","LABEL_1":"it","LABEL_2":"others"}
